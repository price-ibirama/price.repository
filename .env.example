# Node Enviroment
NODE_ENV=
# Applications port, default is 3000
PORT=
# Meta verify token, created by admins and setted on meta painel
META_WEBHOOK_VERIFY_TOKEN=
# Meta test token, valid by 24hours, after is necessary regenerate this token
META_WHATSAPP_ACCESS_TOKEN=
# Meta Phone number production (real)
META_WHATSAPP_PHONE_ID_PROD=
# Meta Phone number test (for tests)
META_WHATSAPP_PHONE_ID_TEST=
# Meta Phone number id used in api (versioned META_WHATSAPP_PHONE_ID_PROD or META_WHATSAPP_PHONE_ID_TEST by enviroment)
META_WHATSAPP_SENDER_PHONE_ID=
# API Sender whatsap message version (https://graph.facebook.com/:VERSION)
META_WHATSAPP_API_VERSION=

# Supabase config integration envs
SUPABASE_URL=
SUPABASE_KEY=